<!--
  dictionary.ejs — Inline dictionary partial (included in students/NH.ejs)
  ════════════════════════════════════════════════════════════════════════════
  Features:
    • Text input with debounced translation (500ms) via CDN translate module
    • Speech recognition (currently commented out in the HTML but JS is active)
    • Looks up words in local vocab data from /api/any-vocab
    • Shows word, meaning, image, and audio

  AUDIT NOTES:
    • XSS: `showWord()` inserts `w.word`, `w.meaning`, and `w.image` directly
      into HTML via template literal — no escaping. If vocab data contains HTML
      or a malicious translation is returned, it will execute.
    • The `processWord()` result is destructured but the processed variables
      (`processedEnglish`, `processedJapanese`) are NEVER USED — the original
      `EnglishWord`/`JapaneseWord` are passed to `showWord()` instead.
    • Speech recognition JS is fully wired up but the HTML button is commented
      out — `new SpeechRecognition()` will throw if API is unavailable.
    • `recognition.onend` clears output even after a successful recognition
      result, which may flash and disappear.
    • `::placeholder` vendor prefixes (:-moz, ::-ms) are outdated — modern
      browsers all support the unprefixed version.
-->
<style>
  ::placeholder { text-align:right; }
  input:-moz-placeholder { text-align:right; }
  ::-ms-input-placeholder { text-align:right; }
</style>


<div class="container-fluid g-0">

  <div class="row">
<!-- SELECT VOCAB FORMS ------------------------------------------------------->
    <div class="col-4">
      <div class="d-flex mt-1">
        <div class="text-muted">DICTIONARY</div>
        <div class="flex-grow-1"><hr/></div>
      </div>

      <input id="searchInput" name="word" type="text"
              class="form-control my-2" placeholder="日本語 / English" style="text-align:right;" autocomplete="off" autocapitalize="none" autocorrect="off" spellcheck="false">

      <!-- <div class="d-flex justify-content-end">
        <div class="text-muted me-3"><%//- __('speech') %></div>
        <div id="speech_recognition" class="btn btn-success">
          <i class="material-icons">mic</i>
        </div>
      </div> -->
    </div>

    <div class="col-8">
      <div id="output"></div>
    </div>


  </div>
</div>


<!-- <script src="javascripts/spell.js" type="text/javascript"></script> -->
<script type="module">
import translate from "https://cdn.jsdelivr.net/npm/translate/index.min.js";

$(function(){
  let typingTimer;
  const typingDelay = 500; // Delay in milliseconds

  var words = {};
  $.get('/api/any-vocab')
    .done((data) => {
      words = data;
    })
    .fail((xhr, status, error) => {
      console.error("Failed to load vocabulary:", error);
      $("#output").html('<div class="alert alert-danger">Failed to load vocabulary. Please try refreshing the page.</div>');
    });


// TEXT INPUT //////////////////////////////////////////////////////////////////
  $('#searchInput').on('input', async function(){
    clearTimeout(typingTimer);
    typingTimer = setTimeout(async () => {
      $("#output").html('<div class="text-center"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>');
      let word = $(this).val();

      let EnglishWord = '';
      let JapaneseWord = '';
      let isJapanese = word.match(/[\u3040-\u30ff\u3400-\u4dbf\u4e00-\u9fff\uf900-\ufaff]/);

      if (word && isJapanese) {
        JapaneseWord = word;
        try{
          EnglishWord = await translate(word, { from: "ja", to: "en" });
        } catch (error) {
          console.error("Translation error:", error);
          EnglishWord = "Translation failed";
        }
      } else if (word) {
        EnglishWord = word;
        try {
          JapaneseWord = await translate(word, { from: "en", to: "ja" });
        } catch (error) {
          console.error("Translation error:", error);
          JapaneseWord = "Translation failed";
        }
      } else {
        $("#output").html('');
        return;
      }

      function processWord(EnglishWord, JapaneseWord) {
        let image = '';
        let audio = '';

        if (Object.keys(words).includes(EnglishWord)) {
          image = `<img src="${words[EnglishWord].image}" class="img-fluid" style="max-height:150px;" alt="${EnglishWord}">`;
          audio = words[EnglishWord].audio;
          if (JapaneseWord != words[EnglishWord].meaning) {
            JapaneseWord += `, ${words[EnglishWord].meaning}`;
          }
        } else {
          let lc = EnglishWord.toLowerCase();
          if (Object.keys(words).includes(lc)) {
            EnglishWord = lc;
            image = `<img src="${words[EnglishWord].image}" class="img-fluid" style="max-height:150px;" alt="${EnglishWord}">`;
            audio = words[lc].audio;
            if (JapaneseWord != words[lc].meaning) {
              JapaneseWord += `, ${words[lc].meaning}`;
            }
          }
        }
        
        return { EnglishWord, JapaneseWord, image, audio };
      }

      const result = processWord(EnglishWord, JapaneseWord);
      showWord({word: result.EnglishWord, meaning: result.JapaneseWord, image: result.image, audio: result.audio});
    }, typingDelay);
  });


// SPEECH RECOGNITION //////////////////////////////////////////////////////////
  // HTML button is commented out — JS commented out to match.
  // Uncomment both the button in the template and the block below to re-enable.
