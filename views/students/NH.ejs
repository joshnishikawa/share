<!--
  students/NH.ejs — New Horizon vocabulary menu page
  ══════════════════════════════════════════════
  Layout: sidebar navbar + NH unit selector + activity menu (spell/type/double/slots)
  + inline dictionary partial.
  Sets window.deck and window.local for vocab activity forms.
-->
<%- include('../head') -%>

<div id="menu-container" class="d-flex">
  <%- include('navbar') -%>

  <div class="container-fluid">
    <div class="row mb-3">
      <div class="col g-0">
        <%- include('../menu/select_NH') -%>
      </div>
    </div>

    <div class="row">
      <div class="col-4">
        <div class="d-flex mt-1">
          <div class="text-muted">VOCAB ACTIVITIES</div>
          <div class="flex-grow-1"><hr/></div>
        </div>

        <div class="menuitemwrapper">
          <%- include('../menu/item_spell') -%>
        </div>
        <div class="menuitemwrapper">
          <%- include('../menu/item_type') -%>
        </div>
        <div class="menuitemwrapper">
          <%- include('../menu/item_double') -%>
        </div>
        <div class="menuitemwrapper">
          <%- include('../menu/item_slots') -%>
        </div>
      </div>

      <div class="col-8">
        <%- include('../dictionary') -%>
      </div>
    </div>
  </div>
</div>



<script>
$(function(){
  var deckType = 'NH';
  window.deck = [];
  window.local = [];

  $(`#NH-tab`).addClass("active");

  $(".menuitem").on('submit', (e)=>{
    e.preventDefault();
    
    if (!window.deck || window.deck.length == 0) {
      alert("<%- __('pleaseSelect') %>");
    }
    else {
      $(e.target).find("input[name='deck']").val(JSON.stringify(window.deck));
      $(e.target).find("input[name='deckType']").val(deckType);
      const formDataArray = $(e.target).serializeArray();
      e.target.submit();
    }
  });

});
</script>

<%- include('../foot') -%>