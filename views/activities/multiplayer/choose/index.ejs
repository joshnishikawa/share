<!--
  multiplayer/choose/index.ejs — Choose activity HTML partial
  ═════════════════════════════════════════════════════════
  Loaded dynamically via $.load() in multiplayer.ejs.
  Provides the DOM structure for the Choose game:
    - Chooser panel: speak button, auto-listen toggle, image grid
    - Guesser panel: selected image preview, word buttons
  Styled with scoped <style> block — CSS classes prefixed with 'choose-'.
  All JS logic lives in multiplayer/activities/choose.js.
-->
<style>
  .thumb {
    width: 100px;
    cursor: pointer;
  }

  #choose-selected-preview {
    max-width: 220px;
    max-height: 220px;
    border-radius: 12px;
    border: 2px solid #3b82f6;
    background: #f8fbff;
    padding: 0.35rem;
  }

  .choose-word {
    cursor: pointer;
    font-size: 1.5rem;
    font-weight: 700;
    border: 2px solid #d3d7de;
    border-radius: 12px;
    background: #f8fafc;
    color: #1f2a37;
    text-align: center;
    margin: 0.35rem;
    padding: 0.6rem 0.4rem;
    transition: transform 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
  }

  .choose-word:hover {
    transform: translateY(-1px);
  }

  .choose-word-selected {
    background: #dbeafe;
    border-color: #3b82f6;
    color: #1e40af;
  }

  .choose-word-correct {
    background: #dcfce7;
    border-color: #22c55e;
    color: #166534;
  }

  .choose-word-incorrect {
    background: #fee2e2;
    border-color: #ef4444;
    color: #991b1b;
  }

  .choose-word-disabled {
    cursor: default;
    opacity: 0.6;
  }

  #choose-status {
    min-height: 2rem;
    font-size: 1.35rem;
    line-height: 1.35;
  }

  #choose-speak-btn {
    min-width: 180px;
  }

  #choose-heard {
    min-height: 1.5rem;
    font-size: 1rem;
  }
</style>

<div class="container">
  <div class="row">
    <div id="choose-status" class="col-12 text-center text-primary fw-bold mb-2"></div>
  </div>

  <div class="row" id="choose-chooser-panel">
    <div class="col-12 text-center mb-2">
      <button id="choose-speak-btn" class="btn btn-primary" type="button">Tap To Speak</button>
      <div class="form-check form-switch d-inline-flex align-items-center ms-3">
        <input class="form-check-input" type="checkbox" id="choose-auto-listen">
        <label class="form-check-label ms-2" for="choose-auto-listen">Auto-listen</label>
      </div>
      <div id="choose-heard" class="text-secondary mt-2"></div>
    </div>
    <div class="col-12 text-center fw-bold text-secondary mb-2">Images</div>
    <div id="choose-images" class="col-12 d-flex flex-wrap justify-content-center"></div>
  </div>

  <div class="row d-none" id="choose-guesser-panel">
    <div class="col-12 text-center fw-bold text-secondary mb-1">Selected Image</div>
    <div class="col-12 text-center mb-2">
      <img id="choose-selected-preview" class="img-fluid d-none" alt="selected image">
    </div>
    <div class="col-12 text-center fw-bold text-secondary mb-2">Words</div>
    <div id="choose-words" class="col-12 d-flex flex-wrap justify-content-center"></div>
  </div>
</div>
